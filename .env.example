# Tavus API key — generate one at https://platform.tavus.io/api-keys
# NOTE: prefixing with VITE_ makes this available in the browser bundle.
# For a production deployment, route API calls through a server you control
# to keep the key private.
VITE_TAVUS_API_KEY=

# Stock replica ID (defaults to Anna — a Phoenix-4 Pro stock replica)
VITE_TAVUS_REPLICA_ID=rf4e9d9790f0

# Stock persona ID. For the emotional-intelligence demo we strongly
# recommend a persona configured with the raven-0 or raven-1 perception
# model so the emotion/perception panels receive real events.
# Default: Sales Development Rep (Anna) stock persona.
VITE_TAVUS_PERSONA_ID=pcb7a34da5fe

# Optional: OpenAI API key for the LLM-based sentiment scorer.
# When present, each user utterance with Raven analysis is scored off the
# main thread by `gpt-4o-mini` (structured output) and the Sentiment panel
# shows real semantic scores. When absent, the panel falls back to the
# built-in keyword scorer.
# https://platform.openai.com/api-keys — same caveat as above: VITE_*
# is exposed to the browser bundle.
VITE_OPENAI_API_KEY=
# Optional override of the model name (default: gpt-4o-mini).
VITE_OPENAI_SENTIMENT_MODEL=gpt-4o-mini
